{
  "name": "obsidian-zk",
  "version": "0.2.12",
  "description": "Obsidian Zettelkasten MCP server with Luhmann numbering",
  "type": "module",
  "bin": {
    "obsidian-zk": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "obsidian",
    "zettelkasten",
    "mcp",
    "luhmann"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "templates"
  ]
}
